name: APK Batch Analysis2

on:
  workflow_dispatch:

jobs:
  analyze:
    runs-on: windows-2025-vs2026   # 显式指定最新镜像，避免重定向

    env:
      FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: 'true'
      PYTHONIOENCODING: 'utf-8'    # 确保 Python 输出编码正确

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Java (for apktool.jar)
        uses: actions/setup-java@v4
        with:
          distribution: 'temurin'
          java-version: '8'

      - name: Set up Python 3.11
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Verify environment
        run: |
          echo "Python version:"
          python --version
          echo "Java version:"
          java -version
          echo "Current directory:"
          dir
          echo "APK directory contents:"
          if exist apk (dir apk) else (echo "apk directory not found")
        shell: cmd

      - name: Run original batch analysis (main.py)
        run: |
          echo "Starting main.py analysis..."
          python main.py
          echo "main.py completed with exit code %ERRORLEVEL%"
        shell: cmd
        continue-on-error: true   # 即使失败也继续执行，便于查看后续步骤

      - name: Run compatibility analysis (apk_compat_analysis.py)
        run: |
          echo "Starting compatibility analysis..."
          if exist apk (
            for %%f in (apk\*.apk) do (
              echo Processing %%f
              python apk_compat_analysis.py "%%f"
              if errorlevel 1 (
                echo "Warning: apk_compat_analysis.py failed for %%f"
              )
            )
          ) else (
            echo "No apk directory found, skipping compatibility analysis"
          )
          echo "Compatibility analysis completed"
        shell: cmd
        continue-on-error: true

      - name: List generated reports
        run: |
          echo "Generated .txt files:"
          dir *.txt /s
        shell: cmd

      - name: Upload analysis results as artifacts
        uses: actions/upload-artifact@v4
        with:
          name: apk-analysis-reports
          path: |
            *.txt
            apk\*.txt
            apk\unpack\*\*.txt
          if-no-files-found: warn
